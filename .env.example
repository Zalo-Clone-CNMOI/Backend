# Shared
NODE_ENV=development

# Firebase (for phone authentication)
# Get these values from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Private key from Firebase service account JSON (keep the \n for newlines)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n"

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=be

# Redis (for ws-gateway Socket.IO adapter)
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGIN=http://localhost:3000

# Scylla
SCYLLA_CONTACT_POINTS=127.0.0.1
SCYLLA_LOCAL_DATACENTER=datacenter1
SCYLLA_KEYSPACE=chat

# Presence (reasonable defaults)
PRESENCE_TTL_MS=60000
PRESENCE_CLEANUP_MS=5000

# Media / S3 (use AWS or LocalStack)
AWS_REGION=ap-southeast-1
S3_BUCKET=be-media
S3_PRESIGN_EXPIRES_SECONDS=60
S3_UPLOAD_PREFIX=uploads/

# LocalStack (optional)
S3_ENDPOINT=http://localhost:4566
S3_FORCE_PATH_STYLE=true

# CDN / Public URL for media files
# For LocalStack local dev: same as S3_ENDPOINT
# For AWS S3 (no CloudFront): leave blank → auto-built as https://{S3_BUCKET}.s3.{AWS_REGION}.amazonaws.com
# For CloudFront: CDN_BASE_URL=https://xxxx.cloudfront.net
CDN_BASE_URL=http://localhost:4566

# Service ports (run 1 service per terminal)
# api-gateway
PORT=3001

# ws-gateway
# PORT=3001
# KAFKA_GROUP_ID=ws-gateway-fanout

# chat-service
# KAFKA_GROUP_ID=chat-service-persist

# presence-service
# KAFKA_GROUP_ID=presence-service-state

# media-service
# PORT=3003

# notification-service
# KAFKA_GROUP_ID=notification-service

# LocDo.Tech AI Router (primary AI provider — OpenAI-compatible proxy for Claude models)
# Obtain key from: https://ai-router.locdo.tech
# When set, this is used as the primary provider before OpenAI/Gemini/Anthropic fallbacks.
LCDO_ROUTER_URL=https://ai-router.locdo.tech
LCDO_ROUTER_KEY=sk-phat-xxxxxxxxxxxxxxxxxxxxx
# Available models: claude-sonnet-4-6 | claude-opus-4.6 | claude-haiku-4.5
LCDO_ROUTER_MODEL=claude-sonnet-4-6

# Internal service URLs (for local dev; in Docker these are auto-resolved by hostname)
AI_CORE_SERVICE_URL=http://localhost:5005/api

# AI moderation fallback policy
# false (recommended): fail-safe, messages are flagged if moderation provider fails
# true: fail-open, messages are treated as clean on moderation errors
AI_MODERATION_FAIL_OPEN=false

# Chat moderation delete-event emit lock TTL (seconds)
# Increase this if Kafka publish latency is high in your environment
CHAT_MODERATION_DELETE_LOCK_TTL_SECONDS=120

# ── Pre-send moderation gate (Phase 5) ─────────────────────────────────
# Blocks toxic messages BEFORE persistence on the chat-service critical
# path. Fail-open: any LLM/HTTP error allows the message through and
# post-persist moderation acts as safety net. All values below are
# defaults baked into the code — set explicitly only to override.

# Master flag — set to false to disable the gate entirely (every message
# proceeds to persistence regardless of body content).
CHAT_PRE_SEND_MODERATION_ENABLED=true

# CSV of conversation types that skip the gate. Values: direct, group,
# ai_assistant. Parser throws on unknown values (fail loud, no silent
# bypass). Default skips DIRECT (small audience) + AI_ASSISTANT (Zai
# conversations — Zai itself is responsible for its own outputs).
CHAT_PRE_SEND_MODERATION_SKIP_CONV_TYPES=direct,ai_assistant

# Hard HTTP timeout (ms) for the chat-service → ai-core moderation call.
# Caller treats timeout as fail-open and lets the message through.
CHAT_PRE_SEND_MODERATION_TIMEOUT_MS=2000

# Confidence threshold (0..1). A flagged result with confidence below
# this is treated as ALLOW. Tune via the pre_send_moderation_total
# Prometheus counter (result=block vs result=allow_llm).
CHAT_PRE_SEND_MODERATION_CONFIDENCE_THRESHOLD=0.85

# Clean-cache TTL (seconds, 24h default). Deduplicates LLM calls for
# common short messages like "ok", "thanks".
CHAT_PRE_SEND_MODERATION_CACHE_TTL_SECONDS=86400

# Block-cache TTL (seconds, 15min default). Deduplicates spam-retry of
# the same toxic string — direct cost-amplification mitigation. Short
# enough that a model/threshold tuning change re-evaluates quickly.
CHAT_PRE_SEND_MODERATION_BLOCK_CACHE_TTL_SECONDS=900

# Coturn TURN/STUN server (required for WebRTC)
COTURN_SECRET=
COTURN_HOST=turn.yourdomain.com
COTURN_PORT=3478

# Zai AI bot — fixed UUID of the seeded Zai user (match migration AddZaiFoundation1782100000000).
# Must be set explicitly in production; defaults to the dev UUID below if unset.
ZAI_BOT_USER_ID=00000000-0000-4000-8000-0000000000a1

# Zai L2 rolling-summary memory (Phase 6) — OFF by default. Enable only after
# telemetry shows conversations regularly exceed the trigger length.
ZAI_L2_MEMORY_ENABLED=false
ZAI_L2_SUMMARY_TRIGGER_TURNS=30

# Zai vision (images-only) — let Zai "see" image attachments.
ZAI_VISION_ENABLED=true
ZAI_VISION_MAX_IMAGES=4
# Inline images as base64 instead of presigned S3 URLs. Set true in dev when
# the object store (LocalStack) is NOT reachable by the LLM router; false in prod.
ZAI_VISION_INLINE_BASE64=false
