# Shared
NODE_ENV=development

# Firebase (for phone authentication)
# Get these values from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Private key from Firebase service account JSON (keep the \n for newlines)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n"

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=be

# Redis (for ws-gateway Socket.IO adapter)
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGIN=http://localhost:3000

# Scylla
SCYLLA_CONTACT_POINTS=127.0.0.1
SCYLLA_LOCAL_DATACENTER=datacenter1
SCYLLA_KEYSPACE=chat

# Presence (reasonable defaults)
PRESENCE_TTL_MS=60000
PRESENCE_CLEANUP_MS=5000

# Media / S3 (use AWS or LocalStack)
AWS_REGION=ap-southeast-1
S3_BUCKET=be-media
S3_PRESIGN_EXPIRES_SECONDS=60
S3_UPLOAD_PREFIX=uploads/

# LocalStack (optional)
S3_ENDPOINT=http://localhost:4566
S3_FORCE_PATH_STYLE=true

# CDN / Public URL for media files
# For LocalStack local dev: same as S3_ENDPOINT
# For AWS S3 (no CloudFront): leave blank → auto-built as https://{S3_BUCKET}.s3.{AWS_REGION}.amazonaws.com
# For CloudFront: CDN_BASE_URL=https://xxxx.cloudfront.net
CDN_BASE_URL=http://localhost:4566

# Service ports (run 1 service per terminal)
# api-gateway
PORT=3001

# ws-gateway
# PORT=3001
# KAFKA_GROUP_ID=ws-gateway-fanout

# chat-service
# KAFKA_GROUP_ID=chat-service-persist

# presence-service
# KAFKA_GROUP_ID=presence-service-state

# media-service
# PORT=3003

# notification-service
# KAFKA_GROUP_ID=notification-service

# AI moderation fallback policy
# false (recommended): fail-safe, messages are flagged if moderation provider fails
# true: fail-open, messages are treated as clean on moderation errors
AI_MODERATION_FAIL_OPEN=false
