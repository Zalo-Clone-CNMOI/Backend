# ================================================
# Environment Variables for Production Deployment
# ================================================
# Copy this file to .env.prod and fill in the values
# NEVER commit the actual .env.prod file to git!
# ================================================

# ================================
# General
# ================================
NODE_ENV=production

# ================================
# Docker Registry
# ================================
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_PREFIX=your-github-username/zalo-clone
IMAGE_TAG=latest

# ================================
# Service Ports (exposed to host)
# ================================
BFF_PORT=5000

# ================================
# Database - PostgreSQL
# ================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=zaloclone

# ================================
# JWT Configuration
# ================================
JWT_SECRET=your_jwt_secret_key_min_32_chars_here

# ================================
# Firebase Configuration
# ================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n"

# ================================
# CORS Configuration
# ================================
# Comma-separated list of allowed origins
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# ================================
# AWS S3 / Media Storage (Optional)
# ================================
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=your-media-bucket
S3_PRESIGN_EXPIRES_SECONDS=300
