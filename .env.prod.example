# ================================================
# Production Environment Variables
# ================================================
# Copy this file to .env.prod and fill in your values
# ================================================

# ================================
# General
# ================================
NODE_ENV=production

# ================================
# Docker Registry Configuration
# ================================
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_PREFIX=your-github-username/zalo-clone
IMAGE_TAG=latest

# ================================
# Service Ports (external)
# ================================
BFF_PORT=5000
MEDIA_PORT=3003
CHAT_PORT=5002
WS_PORT=3001

# ================================
# JWT Configuration
# ================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ================================
# CORS Configuration
# ================================
CORS_ORIGIN=https://your-frontend-domain.com

# ================================
# PostgreSQL (AWS RDS)
# ================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-rds-password
POSTGRES_DB=postgres

# ================================
# Firebase Configuration
# ================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Private key from Firebase service account JSON (keep the \n for newlines)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ================================
# AWS S3 / Media Storage
# ================================
S3_BUCKET=your-s3-bucket-name
S3_ACCESS_KEY_ID=your-aws-access-key-id
S3_SECRET_ACCESS_KEY=your-aws-secret-access-key
S3_FORCE_PATH_STYLE=false
S3_UPLOAD_PREFIX=uploads/
AWS_REGION=ap-southeast-1
S3_PRESIGN_EXPIRES_SECONDS=60

# CDN / Public URL for media files
# - Omit (or leave commented) to auto-build: https://{S3_BUCKET}.s3.{AWS_REGION}.amazonaws.com
# - Set if using CloudFront or custom CDN
# CDN_BASE_URL=https://xxxx.cloudfront.net

# ================================
# Kafka (Internal Docker network)
# ================================
# These are set in docker-compose.prod.yml, no need to change
# KAFKA_BROKERS=kafka:29092

# ================================
# Redis (Internal Docker network)
# ================================
# These are set in docker-compose.prod.yml, no need to change
# REDIS_URL=redis://redis:6379

# ================================
# ScyllaDB (Internal Docker network)
# ================================
# These are set in docker-compose.prod.yml, no need to change
# SCYLLA_CONTACT_POINTS=scylla
# SCYLLA_LOCAL_DATACENTER=datacenter1
# SCYLLA_KEYSPACE=chat
