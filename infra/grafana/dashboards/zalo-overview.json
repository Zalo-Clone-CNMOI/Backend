{
  "uid": "zalo-overview",
  "title": "Zalo Overview",
  "tags": ["zalo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Container up (last seen < 60s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "(time() - container_last_seen{name=~\"zalo_.+\"}) < 60",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "CPU rate per container",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"zalo_.+\"}[5m])",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Memory per container",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"zalo_.+\"}",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Health probe success",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox-health\"}",
          "legendFormat": "{{instance}}"
        }
      ]
    }
  ]
}
