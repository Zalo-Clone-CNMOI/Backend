{
  "name": "be",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "pnpm run build:api",
    "build:bff": "nest build bff-service",
    "build:sso": "nest build sso-service",
    "build:ws": "nest build ws-gateway",
    "build:chat": "nest build chat-service",
    "build:presence": "nest build presence-service",
    "build:media": "nest build media-service",
    "build:notification": "nest build notification-service",
    "build:relation": "nest build relation-service",
    "build:all": "pnpm run build:ws && pnpm run build:chat && pnpm run build:presence && pnpm run build:media && pnpm run build:notification && pnpm run build:bff && pnpm run build:sso && pnpm run build:relation",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\" \"test/**/*.ts\"",
    "start": "pnpm run start:api",
    "start:bff": "nest start bff-service",
    "start:sso": "nest start sso-service",
    "start:ws": "nest start ws-gateway",
    "start:chat": "nest start chat-service",
    "start:presence": "nest start presence-service",
    "start:media": "nest start media-service",
    "start:notification": "nest start notification-service",
    "start:relation": "nest start relation-service",
    "start:dev:bff": "nest start bff-service --watch",
    "start:dev:sso": "nest start sso-service --watch",
    "start:dev:ws": "nest start ws-gateway --watch",
    "start:dev:chat": "nest start chat-service --watch",
    "start:dev:presence": "nest start presence-service --watch",
    "start:dev:media": "nest start media-service --watch",
    "start:dev:notification": "nest start notification-service --watch",
    "start:dev:relation": "nest start relation-service --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/be/test/jest-e2e.json",
    "typeorm": "npx ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "codegen:sso": "openapi-generator-cli generate --generator-key sso-client",
    "migration:generate": "npm run typeorm -- -d libs/database/src/data-source.ts migration:generate ./migrations/$npm_config_name",
    "migration:up": "npm run build && npm run typeorm migration:run -- -d libs/database/src/data-source.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d libs/database/src/data-source.ts",
    "migration:show": "npm run typeorm -- migration:show -d libs/database/src/data-source.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/s3-request-presigner": "^3.758.0",
    "@nest-lab/throttler-storage-redis": "^1.1.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.0.1",
    "@nestjs/swagger": "^11.2.5",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.0.1",
    "@openapitools/openapi-generator-cli": "^2.27.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/body-parser": "^1.19.6",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "cassandra-driver": "^4.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dotenv": "^17.2.3",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "typeorm": "^0.3.28",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/libs/",
      "<rootDir>/apps/"
    ],
    "moduleNameMapper": {
      "^@app/clients(|/.*)$": "<rootDir>/libs/clients/src/$1",
      "^@app/sso-client(|/.*)$": "<rootDir>/libs/sso-client/src/$1",
      "^@app/types(|/.*)$": "<rootDir>/libs/types/src/$1"
    }
  }
}