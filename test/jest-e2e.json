{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": "(e2e-spec|integration\\.spec)\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "roots": [
    "<rootDir>/"
  ],
  "moduleNameMapper": {
    "^@app/clients/interaction-client(|/.*)$": "<rootDir>/../libs/clients/src/interaction-client/src/$1",
    "^@app/clients(|/.*)$": "<rootDir>/../libs/clients/src/$1",
    "^@app/sso-client(|/.*)$": "<rootDir>/../libs/sso-client/src/$1",
    "^@app/types(|/.*)$": "<rootDir>/../libs/types/src/$1",
    "^@app/constant(|/.*)$": "<rootDir>/../libs/constant/src/$1",
    "^@app/decorator(|/.*)$": "<rootDir>/../libs/decorator/src/$1",
    "^@libs/auth(|/.*)$": "<rootDir>/../libs/auth/src/$1",
    "^@libs/contracts(|/.*)$": "<rootDir>/../libs/contracts/src/$1",
    "^@libs/kafka(|/.*)$": "<rootDir>/../libs/kafka/src/$1",
    "^@libs/redis(|/.*)$": "<rootDir>/../libs/redis/src/$1",
    "^@libs/scylla(|/.*)$": "<rootDir>/../libs/scylla/src/$1",
    "^@libs/database(|/.*)$": "<rootDir>/../libs/database/src/$1",
    "^@libs/config(|/.*)$": "<rootDir>/../libs/config/src/$1",
    "^@libs/logger(|/.*)$": "<rootDir>/../libs/logger/src/$1",
    "^@libs/mvp-access(|/.*)$": "<rootDir>/../libs/mvp-access/src/$1",
    "^@libs/shared(|/.*)$": "<rootDir>/../libs/shared/src/$1",
    "^@libs/metrics(|/.*)$": "<rootDir>/../libs/metrics/src/$1",
    "^@libs/firebase(|/.*)$": "<rootDir>/../libs/firebase/src/$1",
    "^@libs/s3(|/.*)$": "<rootDir>/../libs/s3/src/$1",
    "^@libs/swagger(|/.*)$": "<rootDir>/../libs/swagger/src/$1",
    "^@libs/interceptors(|/.*)$": "<rootDir>/../libs/interceptors/src/$1",
    "^@libs/middleware(|/.*)$": "<rootDir>/../libs/middleware/src/$1"
  }
}