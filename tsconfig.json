{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "@app/clients": [
        "libs/clients/src"
      ],
      "@app/clients/*": [
        "libs/clients/src/*"
      ],
      "@app/constant": [
        "libs/constant/src"
      ],
      "@app/constant/*": [
        "libs/constant/src/*"
      ],
      "@app/decorator": [
        "libs/decorator/src"
      ],
      "@app/decorator/*": [
        "libs/decorator/src/*"
      ],
      "@app/interceptors": [
        "libs/interceptors/src"
      ],
      "@app/interceptors/*": [
        "libs/interceptors/src/*"
      ],
      "@app/middleware": [
        "libs/middleware/src"
      ],
      "@app/middleware/*": [
        "libs/middleware/src/*"
      ],
      "@app/sso-client": [
        "libs/clients/src/sso-client/src"
      ],
      "@app/sso-client/*": [
        "libs/clients/src/sso-client/src/*"
      ],
      "@app/clients/interaction-client": [
        "libs/clients/src/interaction-client/src"
      ],
      "@app/clients/interaction-client/*": [
        "libs/clients/src/interaction-client/src/*"
      ],
      "@app/swagger": [
        "libs/swagger/src"
      ],
      "@app/swagger/*": [
        "libs/swagger/src/*"
      ],
      "@app/types": [
        "libs/types/src"
      ],
      "@app/types/*": [
        "libs/types/src/*"
      ],
      "@libs/auth": [
        "libs/auth/src"
      ],
      "@libs/auth/*": [
        "libs/auth/src/*"
      ],
      "@libs/config": [
        "libs/config/src"
      ],
      "@libs/config/*": [
        "libs/config/src/*"
      ],
      "@libs/contracts": [
        "libs/contracts/src"
      ],
      "@libs/contracts/*": [
        "libs/contracts/src/*"
      ],
      "@libs/database": [
        "libs/database/src"
      ],
      "@libs/database/*": [
        "libs/database/src/*"
      ],
      "@libs/firebase": [
        "libs/firebase/src"
      ],
      "@libs/firebase/*": [
        "libs/firebase/src/*"
      ],
      "@libs/kafka": [
        "libs/kafka/src"
      ],
      "@libs/kafka/*": [
        "libs/kafka/src/*"
      ],
      "@libs/logger": [
        "libs/logger/src"
      ],
      "@libs/logger/*": [
        "libs/logger/src/*"
      ],
      "@libs/mvp-access": [
        "libs/mvp-access/src"
      ],
      "@libs/mvp-access/*": [
        "libs/mvp-access/src/*"
      ],
      "@libs/redis": [
        "libs/redis/src"
      ],
      "@libs/redis/*": [
        "libs/redis/src/*"
      ],
      "@libs/s3": [
        "libs/s3/src"
      ],
      "@libs/s3/*": [
        "libs/s3/src/*"
      ],
      "@libs/scylla": [
        "libs/scylla/src"
      ],
      "@libs/scylla/*": [
        "libs/scylla/src/*"
      ],
      "@libs/shared": [
        "libs/shared/src"
      ],
      "@libs/shared/*": [
        "libs/shared/src/*"
      ]
    },
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false
  }
}